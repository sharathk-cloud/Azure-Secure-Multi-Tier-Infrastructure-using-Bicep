{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "lbName": { "value": "ilb-dev-cus-01" },
    "bastion": {
      "value": {
        "pipName": "pip-bas-dev-cus-01",
        "name": "bas-dev-cus-01"
      }
    },
    "winWebAdminPassword": { "value": "DummyPassword123!" },
    "linuxWebAdminPassword": { "value": "DummyPassword123!" },
    "sqlAdminPassword": { "value": "DummyPassword123!" },
    "sqlAdminLogin": { "value": "sqladmin" },
    "winWebConfig": {
      "value": {
        "scriptUri": "https://dummy.blob.core.windows.net/scripts/setup-iis.ps1?dummySASToken",
        "vmSize": "Standard_D2s_v3",
        "adminUserName": "azureadmin",
        "baseName": "dev-app",
        "count": 1
      }
    },
    "linuxWebConfig": {
      "value": {
        "baseName": "dev-app",
        "vmSize": "Standard_D2s_v3",
        "count": 1,
        "adminUsername": "linuxadmin"
      }
    },
    "location": { "value": "centralus" },
    "storageAccountName": { "value": "devstorageacct123" },
    "vnet": {
      "value": {
        "name": "vnet-dev-cus-01",
        "addressPrefixes": ["10.10.0.0/16"],
        "subnets": [
          { "name": "snet-dev-app-01", "prefix": "10.10.0.0/24" },
          { "name": "snet-dev-db-01", "prefix": "10.10.1.0/24" },
          { "name": "AzureBastionSubnet", "prefix": "10.10.2.0/24" }
        ]
      }
    },
    "testvnet": {
      "value": {
        "name": "vnet-dev-staging-01",
        "addressPrefixes": ["10.11.0.0/16"],
        "subnets": [
          { "name": "snet-dev-staging-01", "prefix": "10.11.0.0/24" }
        ]
      }
    },
    "nsg": {
      "value": {
        "name": "nsg-dev-cus-shared-01",
        "rules": [
          {
            "name": "allow-rdp-from-bastion",
            "properties": {
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "3389",
              "sourceAddressPrefix": "10.10.2.0/24",
              "destinationAddressPrefix": "*",
              "access": "Allow",
              "priority": 400,
              "direction": "Inbound"
            }
          }
        ]
      }
    },
    "dbNsg": {
      "value": {
        "name": "nsg-db-prod-cus-01",
        "rules": [
          {
            "name": "in-allow-sql-from-app-subnet",
            "properties": {
              "description": "Allow SQL traffic (port 1433) from App subnet only \u2014 all other sources denied.",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "1433",
              "sourceAddressPrefix": "10.0.0.0/24",
              "destinationAddressPrefix": "10.0.1.0/24",
              "access": "Allow",
              "priority": 100,
              "direction": "Inbound"
            }
          },
          {
            "name": "in-allow-azure-services",
            "properties": {
              "description": "Allow Azure internal services (health probes, backups, monitoring).",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "1433",
              "sourceAddressPrefix": "AzureCloud",
              "destinationAddressPrefix": "10.0.1.0/24",
              "access": "Allow",
              "priority": 200,
              "direction": "Inbound"
            }
          },
          {
            "name": "in-deny-all-other",
            "properties": {
              "description": "Explicitly deny all other inbound traffic to the DB subnet.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*",
              "access": "Deny",
              "priority": 4000,
              "direction": "Inbound"
            }
          }
        ]
      }
    },
    "bastionNsg": {
      "value": {
        "name": "nsg-bas-prod-cus-01",
        "rules": [
          {
            "name": "AllowHttpsInBound",
            "properties": {
              "description": "Required: allow HTTPS management traffic from Internet.",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "443",
              "sourceAddressPrefix": "Internet",
              "destinationAddressPrefix": "*",
              "access": "Allow",
              "priority": 120,
              "direction": "Inbound"
            }
          },
          {
            "name": "AllowGatewayManagerInBound",
            "properties": {
              "description": "Required: allow Azure Gateway Manager control plane traffic.",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "443",
              "sourceAddressPrefix": "GatewayManager",
              "destinationAddressPrefix": "*",
              "access": "Allow",
              "priority": 130,
              "direction": "Inbound"
            }
          },
          {
            "name": "AllowLoadBalancerInBound",
            "properties": {
              "description": "Required: allow Azure Load Balancer health probes.",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "443",
              "sourceAddressPrefix": "AzureLoadBalancer",
              "destinationAddressPrefix": "*",
              "access": "Allow",
              "priority": 140,
              "direction": "Inbound"
            }
          },
          {
            "name": "AllowBastionHostCommunicationInBound",
            "properties": {
              "description": "Required: allow inter-host communication within Bastion.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRanges": [
                "8080",
                "5701"
              ],
              "sourceAddressPrefix": "VirtualNetwork",
              "destinationAddressPrefix": "VirtualNetwork",
              "access": "Allow",
              "priority": 150,
              "direction": "Inbound"
            }
          },
          {
            "name": "AllowSshRdpOutBound",
            "properties": {
              "description": "Required: allow Bastion to reach target VMs via SSH/RDP.",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRanges": [
                "22",
                "3389"
              ],
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "VirtualNetwork",
              "access": "Allow",
              "priority": 100,
              "direction": "Outbound"
            }
          },
          {
            "name": "AllowAzureCloudOutBound",
            "properties": {
              "description": "Required: allow Bastion to reach Azure platform services.",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "443",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "AzureCloud",
              "access": "Allow",
              "priority": 110,
              "direction": "Outbound"
            }
          },
          {
            "name": "AllowBastionHostCommunicationOutBound",
            "properties": {
              "description": "Required: allow inter-host communication within Bastion.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRanges": [
                "8080",
                "5701"
              ],
              "sourceAddressPrefix": "VirtualNetwork",
              "destinationAddressPrefix": "VirtualNetwork",
              "access": "Allow",
              "priority": 120,
              "direction": "Outbound"
            }
          },
          {
            "name": "AllowGetSessionInformationOutBound",
            "properties": {
              "description": "Required: allow session certificate validation over HTTP.",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "80",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "Internet",
              "access": "Allow",
              "priority": 130,
              "direction": "Outbound"
            }
          }
        ]
      }
    },
    "tags": {
      "value": {
        "Environment": "dev",
        "Project": "azure-secure-multi-tier-infra",
        "Owner": "Sharath Kumar",
        "ManagedBy": "Bicep"
      }
    }
  }
}